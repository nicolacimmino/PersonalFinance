meta {
  name: Get Receipts
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/api/v1/receipts
  body: none
  auth: none
}

headers {
  X-API-Key: {{apiKey}}
}

docs {
  Get all receipts (V1 - snake_case).

  Returns receipts with snake_case fields:
  - amount_cents, ext_id, merchant_name, merchant_address, scan_file_name
  - transaction_id, transaction_category, transaction_amount_cents, transaction_currency
  - account_code, account_description
}
